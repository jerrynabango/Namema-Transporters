---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';


const services = [
  {
    icon: 'fa-truck-fast',
    title: 'Freight Forwarding',
    description: 'Comprehensive freight forwarding services for imports and exports. We handle documentation, customs clearance, and door-to-door delivery.',
    detailedDescription: 'Ideal for businesses importing or exporting goods. We manage all paperwork, customs clearance, and coordinate with shipping lines to ensure your cargo moves smoothly across borders.',
    features: ['Air and Sea Freight', 'Customs Clearance', 'Door-to-Door Delivery', 'Cargo Insurance', 'Documentation Handling'],
    color: 'from-blue-500 to-blue-700',
    idealFor: ['Importers', 'Exporters', 'Manufacturers', 'Wholesalers']
  },
  {
    icon: 'fa-truck-moving',
    title: 'Full Truckload (FTL)',
    description: 'Dedicated trucks for large shipments. Your goods travel directly from pickup to destination without multiple stops.',
    detailedDescription: 'Perfect for large volume shipments where you need the entire truck. Your goods are loaded once and delivered directly, reducing handling risks and delivery time.',
    features: ['Exclusive Vehicle', 'Direct Route', 'Express Delivery', 'Real-time Tracking', 'No Multiple Stops'],
    color: 'from-green-500 to-green-700',
    idealFor: ['Large Retailers', 'Manufacturers', 'Construction Companies', 'Bulk Goods']
  },
  {
    icon: 'fa-truck',
    title: 'Less Than Truckload (LTL)',
    description: 'Cost-effective solution for smaller shipments. Share truck space and pay only for the space you use.',
    detailedDescription: 'When you do not need a full truck, we consolidate your shipment with others going the same direction. You pay only for the space you use, making it economical for smaller loads.',
    features: ['Economical Rates', 'Flexible Scheduling', 'Consolidated Shipping', 'Regular Departures', 'Pay per Pallet'],
    color: 'from-purple-500 to-purple-700',
    idealFor: ['Small Businesses', 'Retailers', 'E-commerce Sellers', 'Individual Shipments']
  },
  {
    icon: 'fa-warehouse',
    title: 'Warehousing and Storage',
    description: 'Secure storage facilities with inventory management and distribution services across Kenya.',
    detailedDescription: 'Need temporary or long-term storage? Our warehouses offer climate-controlled options, 24/7 security, and inventory management systems to track your goods.',
    features: ['Climate Control Options', '24/7 Security', 'Inventory Management', 'Order Fulfillment', 'Pick and Pack Services'],
    color: 'from-orange-500 to-orange-700',
    idealFor: ['Retailers', 'E-commerce Businesses', 'Manufacturers', 'Seasonal Stock']
  },
  {
    icon: 'fa-motorcycle',
    title: 'Last Mile Delivery',
    description: 'Fast and efficient last-mile delivery for e-commerce businesses, retailers, and individuals.',
    detailedDescription: 'The final leg of delivery is the most critical. Our last-mile service ensures your packages reach the end customer quickly, with real-time updates and proof of delivery.',
    features: ['Same-day Delivery', 'Real-time Updates', 'Proof of Delivery', 'Cash on Delivery', 'SMS/Email Notifications'],
    color: 'from-pink-500 to-pink-700',
    idealFor: ['E-commerce Stores', 'Online Retailers', 'Restaurants', 'Pharmacies']
  },
  {
    icon: 'fa-boxes',
    title: 'Packing and Moving',
    description: 'Professional packing and moving services for households and offices across Kenya.',
    detailedDescription: 'Moving can be stressful. We provide professional packing materials, trained packers, and careful handling of your belongings for a smooth relocation experience.',
    features: ['Professional Packing', 'Furniture Wrapping', 'Loading/Unloading', 'Storage Options', 'Fragile Item Handling'],
    color: 'from-indigo-500 to-indigo-700',
    idealFor: ['Home Relocation', 'Office Moving', 'Student Housing', 'Apartment Moves']
  },
  {
    icon: 'fa-tractor',
    title: 'Agricultural and Commercial Transport',
    description: 'Specialized transport for farm produce, agricultural inputs, and commercial goods across Kenya.',
    detailedDescription: 'Supporting Kenyan farmers and businesses with reliable transport for agricultural products. From harvest to market, we ensure your fresh produce and commercial goods reach their destination in good condition.',
    features: [
      'Farm Produce Transport (Maize, Tea, Coffee, Sugarcane, Vegetables)',
      'Agricultural Inputs Delivery (Fertilizers, Seeds, Farm Equipment)',
      'Company Products Distribution',
      'Temperature-controlled options for perishables',
      'Flexible scheduling for harvest seasons',
      'Bulk commodity transport'
    ],
    color: 'from-green-600 to-green-800',
    idealFor: ['Farmers', 'Agricultural Cooperatives', 'Food Processors', 'Seed Companies', 'Fertilizer Distributors']
  }
];

// Service areas with coordinates for visual map
const serviceAreas = {
  majorCities: [
    { name: 'Nairobi', region: 'Nairobi County', distance: 'from Luanda: 380km' },
    { name: 'Mombasa', region: 'Coast Region', distance: 'from Luanda: 780km' },
    { name: 'Kisumu', region: 'Kisumu County', distance: 'from Luanda: 45km' },
    { name: 'Nakuru', region: 'Nakuru County', distance: 'from Luanda: 220km' },
    { name: 'Eldoret', region: 'Uasin Gishu', distance: 'from Luanda: 130km' }
  ],
  towns: [
    { name: 'Kakamega', region: 'Kakamega County', distance: 'from Luanda: 60km' },
    { name: 'Bungoma', region: 'Bungoma County', distance: 'from Luanda: 90km' },
    { name: 'Busia', region: 'Busia County', distance: 'from Luanda: 120km' },
    { name: 'Homa Bay', region: 'Homa Bay County', distance: 'from Luanda: 150km' },
    { name: 'Migori', region: 'Migori County', distance: 'from Luanda: 180km' }
  ],
  borderPoints: [
    { name: 'Malaba', country: 'Uganda', distance: 'from Luanda: 140km' },
    { name: 'Busia', country: 'Uganda', distance: 'from Luanda: 120km' },
    { name: 'Namanga', country: 'Tanzania', distance: 'from Luanda: 450km' },
    { name: 'Lunga Lunga', country: 'Tanzania', distance: 'from Luanda: 520km' }
  ]
};
---

<Layout 
  title="Transport and Logistics Services in Kenya | Namema Transporters"
  description="Comprehensive logistics services including freight forwarding, warehousing, last-mile delivery, agricultural transport, and cargo transport across Kenya."
>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="relative bg-gradient-to-r from-namema-primary to-red-700 text-white py-20 overflow-hidden">
      <div class="absolute inset-0 opacity-20">
        <div class="absolute top-10 left-10 w-32 h-32 bg-white rounded-full blur-3xl" style="animation: pulse 3s ease-in-out infinite;"></div>
        <div class="absolute bottom-10 right-10 w-48 h-48 bg-yellow-400 rounded-full blur-3xl" style="animation: pulse 3s ease-in-out infinite 1s;"></div>
      </div>
      <div class="container mx-auto px-4 text-center relative z-10">
        <h1 class="text-4xl md:text-6xl font-bold mb-4" style="animation: fadeInUp 0.8s ease-out forwards">Our Transport Services</h1>
        <p class="text-xl max-w-3xl mx-auto" style="animation: fadeInUp 0.8s ease-out forwards 0.2s; opacity: 0; animation-fill-mode: forwards">Complete logistics solutions for businesses, farmers, and individuals</p>
      </div>
    </section>
    
    <!-- Services Grid -->
    <section class="py-20 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-namema-dark mb-4 reveal">What We Offer</h2>
          <p class="text-gray-600 max-w-2xl mx-auto reveal" style="transition-delay: 0.2s">Complete logistics solutions for businesses, farmers, and individuals across Kenya</p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {services.map((service, index) => (
            <div 
              class="service-card bg-white rounded-2xl shadow-lg overflow-hidden transition-all duration-500 reveal"
              style={`transition-delay: ${index * 0.1}s`}
            >
              <div class={`bg-gradient-to-r ${service.color} p-6 text-white relative overflow-hidden group`}>
                <div class="absolute -right-6 -top-6 w-24 h-24 bg-white opacity-10 rounded-full"></div>
                <div class="relative z-10">
                  <div class="text-5xl mb-3 transform group-hover:scale-110 transition-transform duration-300">
                    <i class={`fas ${service.icon}`}></i>
                  </div>
                  <h3 class="text-2xl font-bold">{service.title}</h3>
                </div>
              </div>
              <div class="p-6">
                <p class="text-gray-600 mb-3 leading-relaxed">{service.description}</p>
                
                <!-- Detailed explanation -->
                <details class="mt-3 mb-3 group">
                  <summary class="text-sm text-namema-primary cursor-pointer hover:text-red-700 font-semibold">
                    Learn more about this service
                  </summary>
                  <p class="text-gray-500 text-sm mt-2 pt-2 border-t border-gray-100">{service.detailedDescription}</p>
                </details>
                
                <ul class="space-y-2 mb-4 mt-4">
                  {service.features.map(feature => (
                    <li class="flex items-center text-sm text-gray-700">
                      <i class="fas fa-check-circle text-namema-primary mr-2 text-xs"></i>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                
                <!-- Ideal for section -->
                <div class="bg-gray-50 rounded-lg p-3 mb-4">
                  <p class="text-xs font-semibold text-namema-dark mb-1">Ideal for:</p>
                  <div class="flex flex-wrap gap-1">
                    {service.idealFor.map(customer => (
                      <span class="text-xs text-gray-600 bg-white px-2 py-0.5 rounded-full">{customer}</span>
                    ))}
                  </div>
                </div>
                
                <a 
                  href="/quote" 
                  class="inline-flex items-center text-namema-primary font-semibold hover:text-red-700 transition group w-full justify-center bg-gray-50 py-2 rounded-lg mt-2"
                >
                  Get Quote 
                  <i class="fas fa-arrow-right ml-2"></i>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Process Section with Pattern Background -->
    <section class="py-20 bg-gradient-to-br from-gray-900 to-gray-800 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cartographer.png')]"></div>
      </div>
      <div class="container mx-auto px-4 relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-white reveal">How It Works</h2>
        <p class="text-center text-gray-300 mb-12 max-w-2xl mx-auto reveal" style="transition-delay: 0.2s">Simple 4-step process to get your goods delivered</p>
        
        <div class="grid md:grid-cols-4 gap-8">
          {[
            { step: '01', title: 'Request Quote', desc: 'Contact us with your shipping details, cargo type, and destination', icon: 'fa-file-signature' },
            { step: '02', title: 'Get Pricing', desc: 'Receive competitive rates instantly based on your needs', icon: 'fa-tag' },
            { step: '03', title: 'Schedule Pickup', desc: 'Arrange convenient pickup time from your location', icon: 'fa-calendar-alt' },
            { step: '04', title: 'Track and Deliver', desc: 'Real-time tracking until your cargo reaches destination', icon: 'fa-map-marked-alt' }
          ].map((item, index) => (
            <div class="text-center group reveal" style={`transition-delay: ${index * 0.15}s`}>
              <div class="relative mb-6">
                <div class="w-24 h-24 mx-auto bg-white rounded-full flex items-center justify-center shadow-2xl transform group-hover:scale-110 transition duration-300">
                  <i class={`fas ${item.icon} text-3xl text-namema-primary`}></i>
                </div>
                <div class="absolute -top-2 -right-2 w-8 h-8 bg-namema-secondary rounded-full flex items-center justify-center text-sm font-bold text-namema-dark">
                  {item.step}
                </div>
              </div>
              <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
              <p class="text-gray-300 text-sm">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Service Areas -->
    <section class="py-20 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-namema-dark mb-4 reveal">Service Areas in Kenya</h2>
          <p class="text-gray-600 max-w-2xl mx-auto reveal" style="transition-delay: 0.2s">We deliver across Kenya with focus on efficiency and reliability</p>
        </div>
        
        <div class="grid lg:grid-cols-3 gap-8">
          <!-- Major Cities -->
          <div class="bg-white rounded-2xl p-6 shadow-lg reveal hover:shadow-xl transition-all duration-300">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-namema-primary rounded-lg flex items-center justify-center mr-3">
                <i class="fas fa-city text-white text-xl"></i>
              </div>
              <h3 class="text-xl font-bold text-namema-dark">Major Cities</h3>
            </div>
            <div class="space-y-3">
              {serviceAreas.majorCities.map((city, idx) => (
                <div class="group relative overflow-hidden rounded-lg bg-gray-50 p-3 hover:bg-gray-100 transition-all duration-300 transform hover:translate-x-2">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <i class="fas fa-map-marker-alt text-namema-primary mr-3"></i>
                      <div>
                        <div class="font-semibold text-gray-800">{city.name}</div>
                        <div class="text-xs text-gray-500">{city.region}</div>
                      </div>
                    </div>
                    <div class="text-xs text-namema-primary font-semibold">{city.distance}</div>
                  </div>
                  <div class="absolute bottom-0 left-0 h-0.5 bg-namema-primary w-0 group-hover:w-full transition-all duration-300"></div>
                </div>
              ))}
            </div>
          </div>
          
          <!-- Major Towns -->
          <div class="bg-white rounded-2xl p-6 shadow-lg reveal hover:shadow-xl transition-all duration-300" style="transition-delay: 0.2s">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-namema-primary rounded-lg flex items-center justify-center mr-3">
                <i class="fas fa-map-marker-alt text-white text-xl"></i>
              </div>
              <h3 class="text-xl font-bold text-namema-dark">Major Towns</h3>
            </div>
            <div class="space-y-3">
              {serviceAreas.towns.map((town, idx) => (
                <div class="group relative overflow-hidden rounded-lg bg-gray-50 p-3 hover:bg-gray-100 transition-all duration-300 transform hover:translate-x-2">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <i class="fas fa-map-marker-alt text-namema-primary mr-3"></i>
                      <div>
                        <div class="font-semibold text-gray-800">{town.name}</div>
                        <div class="text-xs text-gray-500">{town.region}</div>
                      </div>
                    </div>
                    <div class="text-xs text-namema-primary font-semibold">{town.distance}</div>
                  </div>
                  <div class="absolute bottom-0 left-0 h-0.5 bg-namema-primary w-0 group-hover:w-full transition-all duration-300"></div>
                </div>
              ))}
            </div>
          </div>
          
          <!-- Border Points -->
          <div class="bg-white rounded-2xl p-6 shadow-lg reveal hover:shadow-xl transition-all duration-300" style="transition-delay: 0.4s">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-namema-primary rounded-lg flex items-center justify-center mr-3">
                <i class="fas fa-passport text-white text-xl"></i>
              </div>
              <h3 class="text-xl font-bold text-namema-dark">Border Points</h3>
            </div>
            <div class="space-y-3">
              {serviceAreas.borderPoints.map((border, idx) => (
                <div class="group relative overflow-hidden rounded-lg bg-gray-50 p-3 hover:bg-gray-100 transition-all duration-300 transform hover:translate-x-2">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <i class="fas fa-map-marker-alt text-namema-primary mr-3"></i>
                      <div>
                        <div class="font-semibold text-gray-800">{border.name}</div>
                        <div class="text-xs text-gray-500">to {border.country}</div>
                      </div>
                    </div>
                    <div class="text-xs text-namema-primary font-semibold">{border.distance}</div>
                  </div>
                  <div class="absolute bottom-0 left-0 h-0.5 bg-namema-primary w-0 group-hover:w-full transition-all duration-300"></div>
                </div>
              ))}
            </div>
          </div>
        </div>
        
        <!-- Coverage Map Visualization -->
        <div class="mt-12 bg-namema-primary/5 rounded-2xl p-6 reveal">
          <div class="text-center mb-6">
            <i class="fas fa-truck-fast text-3xl text-namema-primary mb-2"></i>
            <h3 class="text-xl font-bold text-namema-dark">Complete Nationwide Coverage</h3>
            <p class="text-gray-500 text-sm">From Luanda to every corner of Kenya</p>
          </div>
          <div class="relative h-2 bg-gray-200 rounded-full overflow-hidden">
            <div class="absolute left-0 top-0 h-full bg-namema-primary rounded-full" style="width: 100%;"></div>
          </div>
          <div class="flex justify-between mt-2 text-xs text-gray-500">
            <span>Luanda HQ</span>
            <span>Western Kenya</span>
            <span>Rift Valley</span>
            <span>Nairobi</span>
            <span>Coast</span>
          </div>
        </div>
      </div>
    </section>
    
    <!-- CTA Section -->
    <section class="py-20 bg-gradient-to-r from-namema-primary to-red-800 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-10 -left-20 w-40 h-40 bg-white rounded-full" style="animation: bounce-slow 3s ease-in-out infinite;"></div>
        <div class="absolute bottom-10 -right-20 w-60 h-60 bg-yellow-400 rounded-full" style="animation: bounce-slow 3s ease-in-out infinite 1s;"></div>
      </div>
      <div class="container mx-auto px-4 text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 reveal">Need Transport Services?</h2>
        <p class="text-xl mb-8 reveal" style="transition-delay: 0.2s">Get a free, no-obligation quote today</p>
        <a 
          href="/quote" 
          class="inline-flex items-center bg-namema-secondary text-namema-dark px-8 py-3 rounded-lg font-bold hover:bg-yellow-500 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl reveal"
          style="transition-delay: 0.4s"
        >
          Request Quote <i class="fas fa-arrow-right ml-2"></i>
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppButton />
</Layout>

<!-- Scripts and Styles -->
<script>
  import '../scripts/services.js';
</script>

<style is:global>
  @import '../styles/services.css';
</style>
