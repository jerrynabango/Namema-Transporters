---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const lastUpdated = "2026-05-24";
---

<Layout 
  title="Privacy Policy | Namema Transporters"
  description="Namema Transporters respects your privacy. Learn how we handle your personal information when you request quotes, contact us, or use our transport and logistics services in Kenya."
>
  <Header />
  
  <main>
    <section class="relative bg-gradient-to-r from-namema-primary to-red-700 text-white py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Privacy Policy</h1>
        <p class="text-xl max-w-3xl mx-auto">How we protect and handle your information</p>
        <p class="text-sm mt-4 text-white/80">Effective Date: {lastUpdated}</p>
      </div>
    </section>
    
    <section class="py-20">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="bg-white rounded-lg shadow-xl p-8 md:p-12">
          
          <!-- Introduction -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">1. Introduction</h2>
            <p class="text-gray-600 leading-relaxed mb-3">
              Namema Transporters ("we", "our", "us", "the Company") is a transport and logistics company based in Luanda, Vihiga County, Kenya. We provide freight forwarding, cargo transport, warehousing, and delivery services across Kenya.
            </p>
            <p class="text-gray-600 leading-relaxed">
              This Privacy Policy explains how we collect, use, and protect the information you provide when you request quotes, contact us via phone, WhatsApp, email, or our online forms, or use our transport services.
            </p>
          </div>
          
          <!-- Information We Collect -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">2. Information We Collect</h2>
            
            <p class="text-gray-600 leading-relaxed mb-3">
              As a transport and logistics company, we collect only the information necessary to provide our services to you.
            </p>
            
            <h3 class="text-xl font-semibold text-namema-primary mt-4 mb-2">2.1 Information You Provide to Us</h3>
            <p class="text-gray-600 leading-relaxed mb-2">When you request a quote, book our services, or contact us, we may collect:</p>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li><strong>Contact Information:</strong> Your full name, phone number(s), and email address</li>
              <li><strong>Location Details:</strong> Pickup address, delivery address, and any special location instructions</li>
              <li><strong>Shipment Information:</strong> Type of cargo, weight, dimensions, quantity, and special handling requirements</li>
              <li><strong>Company Details:</strong> Business name (if applicable)</li>
              <li><strong>Communication Records:</strong> Records of our phone calls, WhatsApp conversations, and email correspondence</li>
              <li><strong>Quote and Booking History:</strong> Records of your previous quotes and transport bookings</li>
            </ul>
            
            <h3 class="text-xl font-semibold text-namema-primary mt-6 mb-2">2.2 Information We Collect When You Use Our Website</h3>
            <p class="text-gray-600 leading-relaxed mb-2">Our website collects minimal information:</p>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li><strong>Form Submissions:</strong> The information you voluntarily enter into our contact or quote forms</li>
              <li><strong>File Attachments:</strong> Any documents or images you choose to upload (e.g., photos of items to transport, inventory lists)</li>
            </ul>
            <p class="text-gray-600 leading-relaxed mt-2">
              <strong>Note:</strong> We do not automatically collect IP addresses, browser information, or use tracking cookies for marketing purposes. Our website uses only essential cookies for basic functionality.
            </p>
            
            <h3 class="text-xl font-semibold text-namema-primary mt-6 mb-2">2.3 Information From Communication Channels</h3>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li><strong>Phone Calls:</strong> When you call us, we may record your phone number and keep notes about our conversation regarding your transport needs</li>
              <li><strong>WhatsApp:</strong> Your phone number and chat history when you contact us via WhatsApp</li>
              <li><strong>SMS/Text Messages:</strong> Your phone number and message content when you text us</li>
            </ul>
          </div>
          
          <!-- How We Use Your Information -->
          <div class="mb-8 bg-gray-50 p-6 rounded-lg">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">3. How We Use Your Information</h2>
            <p class="text-gray-600 leading-relaxed mb-3">We use your information exclusively for transport and logistics purposes:</p>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li>To provide you with accurate transport quotes</li>
              <li>To schedule and coordinate pickups and deliveries</li>
              <li>To communicate with you about your shipment status</li>
              <li>To assign appropriate vehicles and drivers for your cargo</li>
              <li>To generate delivery notes, waybills, and transport documentation</li>
              <li>To process payments and issue receipts</li>
              <li>To respond to your inquiries and provide customer support</li>
              <li>To maintain records of our business relationship with you</li>
              <li>To improve our transport services based on customer feedback</li>
              <li>To comply with legal and regulatory requirements for transport companies in Kenya</li>
            </ul>
            <p class="text-gray-600 leading-relaxed mt-3">
              <strong>Important:</strong> We do not sell, rent, or trade your personal information to third parties for marketing purposes.
            </p>
          </div>
          
          <!-- Legal Basis -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">4. Legal Basis for Processing</h2>
            <p class="text-gray-600 leading-relaxed mb-2">Under Kenyan law (Data Protection Act, 2019), we process your information based on:</p>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li><strong>Contract Performance:</strong> To fulfill our transport agreement with you</li>
              <li><strong>Legal Obligation:</strong> To maintain transport records as required by Kenyan transport regulations</li>
              <li><strong>Legitimate Interest:</strong> To operate our transport business and communicate with customers</li>
              <li><strong>Consent:</strong> When you voluntarily provide information through our forms or communication channels</li>
            </ul>
          </div>
          
          <!-- Information Sharing -->
          <div class="mb-8 bg-gray-50 p-6 rounded-lg">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">5. Information Sharing and Disclosure</h2>
            <p class="text-gray-600 leading-relaxed mb-3">We share your information only when necessary for transport operations:</p>
            
            <h3 class="text-lg font-semibold text-namema-primary mt-3 mb-2">5.1 Drivers and Logistics Staff</h3>
            <p class="text-gray-600 leading-relaxed mb-2">
              Your name, pickup/delivery addresses, and cargo information are shared with our drivers and operations team to execute your transport request. This information is provided on a need-to-know basis.
            </p>
            
            <h3 class="text-lg font-semibold text-namema-primary mt-3 mb-2">5.2 Legal and Regulatory Authorities</h3>
            <p class="text-gray-600 leading-relaxed mb-2">
              We may disclose your information when required by law, court order, or government regulation, including:
            </p>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li>Kenya Revenue Authority (KRA) for tax compliance</li>
              <li>National Transport and Safety Authority (NTSA)</li>
              <li>Law enforcement agencies investigating criminal activity</li>
              <li>Customs authorities for cross-border shipments</li>
            </ul>
            
            <h3 class="text-lg font-semibold text-namema-primary mt-3 mb-2">5.3 Third-Party Service Providers</h3>
            <p class="text-gray-600 leading-relaxed">
              We do not share your personal information with third parties except as necessary for payment processing (e.g., bank or mobile money provider) or when you request cross-border transport that requires customs clearance.
            </p>
          </div>
          
          <!-- Data Security - Practical Measures -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">6. Data Security</h2>
            <p class="text-gray-600 leading-relaxed mb-3">
              As a transport company, we take reasonable measures to protect your information:
            </p>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li>Physical records (delivery notes, waybills) are stored securely at our Luanda office</li>
              <li>Digital records are stored on password-protected computers with limited staff access</li>
              <li>WhatsApp and phone conversations are handled by trained staff who respect customer privacy</li>
              <li>Form submissions are transmitted securely to our business email</li>
              <li>Paper records are disposed of through secure shredding after the required retention period</li>
            </ul>
            <p class="text-gray-600 leading-relaxed mt-3">
              While we implement these security measures, no method of transmission over the internet or mobile networks is 100% secure. We encourage you to avoid sending sensitive information via unsecured channels.
            </p>
          </div>
          
          <!-- Data Retention -->
          <div class="mb-8 bg-gray-50 p-6 rounded-lg">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">7. Data Retention</h2>
            <p class="text-gray-600 leading-relaxed mb-3">
              We retain your information according to transport industry standards and legal requirements:
            </p>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li><strong>Transport Records:</strong> Waybills, delivery notes, and transport documentation are retained for 5 years as required by Kenyan transport regulations</li>
              <li><strong>Customer Communication:</strong> Email, WhatsApp, and call records are retained for 2 years for customer service and dispute resolution purposes</li>
              <li><strong>Quote Requests:</strong> Quote records are retained for 1 year</li>
              <li><strong>Payment Records:</strong> Receipts and payment records are retained for 7 years for tax compliance</li>
            </ul>
            <p class="text-gray-600 leading-relaxed mt-3">
              After the retention period expires, your information is securely deleted or anonymized.
            </p>
          </div>
          
          <!-- Your Rights - Kenyan Data Protection -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">8. Your Rights</h2>
            <p class="text-gray-600 leading-relaxed mb-3">
              Under Kenya's Data Protection Act (2019), you have the following rights:
            </p>
            <ul class="list-disc list-inside text-gray-600 space-y-1 ml-4">
              <li><strong>Right to Access:</strong> Request a copy of the personal information we hold about you</li>
              <li><strong>Right to Correction:</strong> Ask us to correct inaccurate or incomplete information</li>
              <li><strong>Right to Deletion:</strong> Request deletion of your information (subject to legal retention requirements)</li>
              <li><strong>Right to Withdraw Consent:</strong> Opt out of any marketing communications</li>
              <li><strong>Right to Object:</strong> Object to how we process your information</li>
              <li><strong>Right to Lodge a Complaint:</strong> File a complaint with the Office of the Data Protection Commissioner (ODPC)</li>
            </ul>
            <p class="text-gray-600 leading-relaxed mt-3">
              To exercise these rights, contact our Data Protection Officer at <a href="mailto:info@namematransporters.co.ke" class="text-namema-primary hover:underline">info@namematransporters.co.ke</a> or call us at <a href="tel:+254712345678" class="text-namema-primary hover:underline">+254 712 345 678</a>.
            </p>
          </div>
          
          <!-- Cookies -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">9. Cookies and Website Tracking</h2>
            <p class="text-gray-600 leading-relaxed">
              Our website does not use tracking cookies, analytics tools, or collect IP addresses for marketing purposes. We use only essential cookies required for basic website functionality (such as form submissions). You can disable cookies in your browser settings without affecting our website's core functionality.
            </p>
          </div>
          
          <!-- Children's Privacy -->
          <div class="mb-8 bg-gray-50 p-6 rounded-lg">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">10. Children's Privacy</h2>
            <p class="text-gray-600 leading-relaxed">
              Our transport services are intended for adults and businesses. We do not knowingly collect personal information from individuals under 18 years of age. If we discover that we have inadvertently collected information from a minor, we will delete it promptly.
            </p>
          </div>
          
          <!-- Updates to This Policy -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">11. Updates to This Privacy Policy</h2>
            <p class="text-gray-600 leading-relaxed">
              We may update this Privacy Policy from time to time to reflect changes in our practices or legal requirements. The updated policy will be posted on our website with the effective date. For significant changes, we may notify you via SMS or email if you have provided these details.
            </p>
          </div>
          
          <!-- Contact Information -->
          <div class="mb-8 bg-gradient-to-r from-namema-primary/10 to-red-100 p-6 rounded-lg">
            <h2 class="text-2xl font-bold text-namema-dark mb-4">12. Contact Us</h2>
            <p class="text-gray-600 leading-relaxed mb-6">
              If you have questions about this Privacy Policy or how we handle your information, please contact us:
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="flex items-center gap-3 bg-white/50 p-3 rounded-lg">
                <div class="bg-namema-primary/20 p-2 rounded-full w-10 h-10 flex items-center justify-center">
                  <i class="fas fa-envelope text-namema-primary"></i>
                </div>
                <div>
                  <p class="text-xs text-gray-500">Privacy Questions</p>
                  <a href="mailto:info@namematransporters.co.ke" class="text-namema-primary hover:underline font-medium">info@namematransporters.co.ke</a>
                </div>
              </div>
              <div class="flex items-center gap-3 bg-white/50 p-3 rounded-lg">
                <div class="bg-namema-primary/20 p-2 rounded-full w-10 h-10 flex items-center justify-center">
                  <i class="fas fa-phone-alt text-namema-primary"></i>
                </div>
                <div>
                  <p class="text-xs text-gray-500">Call Us</p>
                  <a href="tel:+254712345678" class="text-namema-primary hover:underline font-medium">+254 712 345 678</a>
                </div>
              </div>
              <div class="flex items-center gap-3 bg-white/50 p-3 rounded-lg">
                <div class="bg-namema-primary/20 p-2 rounded-full w-10 h-10 flex items-center justify-center">
                  <i class="fab fa-whatsapp text-namema-primary"></i>
                </div>
                <div>
                  <p class="text-xs text-gray-500">WhatsApp Us</p>
                  <a href="https://wa.me/254723456789" class="text-namema-primary hover:underline font-medium">+254 723 456 789</a>
                </div>
              </div>
              <div class="flex items-center gap-3 bg-white/50 p-3 rounded-lg">
                <div class="bg-namema-primary/20 p-2 rounded-full w-10 h-10 flex items-center justify-center">
                  <i class="fas fa-map-marker-alt text-namema-primary"></i>
                </div>
                <div>
                  <p class="text-xs text-gray-500">Physical Address</p>
                  <p class="text-gray-700 text-sm">Luanda Town, Along Luanda-Kisumu Road, Vihiga County</p>
                </div>
              </div>
            </div>
            <div class="mt-4 pt-3 border-t border-white/50 text-center">
              <p class="text-sm text-gray-600">📬 P.O. Box 123 - 50307, Luanda, Kenya</p>
            </div>
          </div>
          
          <!-- Complaint Lodging -->
          <div class="text-center pt-6 border-t border-gray-200">
            <p class="text-sm text-gray-600">
              <i class="fas fa-gavel text-namema-primary mr-2"></i>
              If you are not satisfied with our response to your privacy concern, you have the right to lodge a complaint with the 
              <a href="https://www.odpc.go.ke/" target="_blank" rel="noopener noreferrer" class="text-namema-primary hover:underline font-medium">Office of the Data Protection Commissioner (ODPC) Kenya</a>.
            </p>
          </div>
          
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppButton />
</Layout>