---
export interface Props {
  icon: string;
  title: string;
  description: string;
  features?: string[];
  delay?: number;
}

const { icon, title, description, features = [], delay = 0 } = Astro.props;
---

<div 
  class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group"
  style={`animation-delay: ${delay}s`}
>
  <div class="bg-namema-primary p-6 text-white">
    <div class="text-4xl mb-2">
      <i class={`fas ${icon}`}></i>
    </div>
    <h3 class="text-xl font-bold">{title}</h3>
  </div>
  
  <div class="p-6">
    <p class="text-gray-600 mb-4">{description}</p>
    
    {features.length > 0 && (
      <ul class="space-y-2 mb-4">
        {features.map(feature => (
          <li class="flex items-center text-sm text-gray-600">
            <i class="fas fa-check-circle text-namema-primary mr-2 text-xs"></i>
            {feature}
          </li>
        ))}
      </ul>
    )}
    
    <a 
      href="/quote" 
      class="inline-flex items-center text-namema-primary font-semibold group-hover:underline transition"
    >
      Learn More 
      <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition"></i>
    </a>
  </div>
</div>
